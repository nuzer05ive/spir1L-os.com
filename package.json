{
  "name": "spir1l-os-core",
  "version": "4.7.1",
  "private": true,
  "workspaces": [
    "spirill-rii-toolchain/*"
  ],
  "scripts": {
    "hv221:run": "ts-node src/harmonic-harness.ts",
    "hv221:test": "jest --selectProjects hv221",
    "hv221:chart": "node build/hv221-chart.js",
    "hv221:report": "node build/hv221-report.js",
    "pxk:simulate": "ts-node src/portal-sim.ts",
