    "tiime": "node scripts/tiime-cli.js"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "ts-node": "^10",
    "jest": "^29",
    "@types/jest": "^29",
    "ascii-histogram": "^1.1.0"
  }
}
