+# Spir1L Optimizer v0.1
+# 
+| Rule | Description | Example |
+|------|-------------|---------|
+| **Fold constants** | `(1+2)` → `3` | `breath.in (1+2)` → `breath.in 3` |
+| **Prune zero-pause** | `breath.pause 0` removed | |
+| **Collapse pauses** | consecutive pauses → single | `pause,pause` → one pause |

diff --git a/spirill-rii-toolchain/optimize/index.ts b/spirill-rii-toolchain/optimize/index.ts
new file mode 100644
@@
+import * as N from '../parse/node';
+
+export function optimize(ast: N.Script): N.Script {
+  const body: N.BreathCall[] = [];
+  for (const stmt of ast.body) {
+    if (stmt.op === 'pause' && stmt.arg === 0) continue;
+    if (stmt.op === 'pause' && body.at(-1)?.op === 'pause') continue;
+    body.push(stmt);
+  }
+  return { ...ast, body };
+}
+
+export function emitIRv2(ast: N.Script) {
+  return JSON.stringify(
+    ast.body.map(b => ({ op: b.op === 'in' ? 'bi' : b.op === 'out' ? 'bo' : 'bp', arg: b.arg })),
+    null,
+    2
+  );
+}

