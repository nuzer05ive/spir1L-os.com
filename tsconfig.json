{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "jest"
    ],
    "outDir": "build",
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src",
    "spirill-rii-toolchain",
    "src/types",
    "types"
  ]
}
